{
  "PreToolUse": [
    {
      "matcher": "Task|SubagentSpawn|Bash|Write|Edit|MultiEdit|WebFetch",
      "hooks": [
        {
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/skills/ystar-govern/check.py --action ${TOOL_NAME} --params '${TOOL_INPUT_JSON}' --principal ${AGENT_ID} --actor subagent"
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python -c \"import json,sys; d=json.loads(sys.stdin.read() or '{}'); print(f'[Y*gov] Subagent {d.get(\\\"agent_id\\\",\\\"?\\\")}: completed')\""
        }
      ]
    }
  ]
}
