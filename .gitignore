# Y*gov runtime database
.ystar_cieu.db
.ystar_cieu_omission.db
.ystar_session.json

# Credentials and runtime state (NEVER commit)
*.session
ystar_telegram_session.session
.ystar_active_agent

# SQLite temp files
*.db-shm
*.db-wal

# Source code (managed separately)
/src/

# Python
__pycache__/
*.pyc

# Environment
.env

# Claude Code local settings
.claude/settings.local.json
.claude/worktrees/

# Runtime
scripts/.session_call_count
scripts/.session_booted

# OpenClaw config (may contain bot tokens)
.openclaw/config.json
openclaw.json
.openclaw/*.json

# === Video / image experiment products (regenerable, large) ===
docs/*.mp4
docs/*.webm
docs/*.mov
docs/*.png
docs/*.jpg
docs/*.jpeg
docs/*.webp
docs/*.ogg

# === YGVA volatile state (regenerable by tools/cieu/ygva/) ===
tools/cieu/ygva/causal_model.json
tools/cieu/ygva/seg2_cieu*.json
tools/cieu/ygva/segB_reference.json
