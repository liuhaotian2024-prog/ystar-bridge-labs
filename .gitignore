# Runtime logs - do NOT push
knowledge/*/gaps/*.log
*.session
*.session-journal
scripts/hook_debug.log
reports/daily/wakeup.log

# Runtime state databases - do NOT push
.ystar_memory.db
.ystar_omission.db
.gov_mcp_state.db
.ystar_cieu.db

# Session runtime state - do NOT push
.ystar_session.json
.ystar_session.json.bak.*
.ystar_article11_warnings
.ystar_session_flags
scripts/.session_booted
scripts/.session_call_count
scripts/.k9_last_read

# Video/binary assets (too large for git)
docs/*.mp4
docs/*.png

# Task locks
.claude/scheduled_tasks.lock

# Agent frontmatter fix backups (local-only)
.claude/agents/*.pre_csuite_fix
reports/_*.py
reports/_backfill.py
reports/_fix_*.py
reports/.commit_msg_*.txt
reports/.msg.txt

# More runtime state (2026-04-13)
.ystar_active_agent
.ystar_ceo_mode.json
.ystar_memory.db-shm
.ystar_memory.db-wal
.ystar_cieu_omission.db
.ystar_retro_baseline.db
.ystar_services_installed
.ystar_session.json.pre_override.*
.openclaw/
.labs_rag_index.pkl
.claude/settings.local.json
memory/boot_packages/*.json
memory/boot_packages/history/
memory/working_memory_snapshot_*.json
memory/sleep_digest_*.md
memory/subjective_state_*.md
memory/_curate_cache/

# Boot packages (runtime memory)
memory/boot_packages/*.json
memory/session_handoff.md

# Active task tracking (runtime state)
knowledge/*/active_task.json

# API keys (never commit)
.env
.envrc
knowledge/secretary/secrets/*
.github/
ystar.egg-info/
.ystar_warning_queue.json

# Python virtualenv (per Milestone 13b gitignore sweep)
**/.venv/
scripts/meeting_room/.venv/

# Per-agent brain.db (large mutable, backup via S3 not git)
*_brain.db
*_brain.db-shm
*_brain.db-wal

# Runtime lock/pid files
*.ppid_*
*.lock
scripts/.agent_stack.ppid_*
